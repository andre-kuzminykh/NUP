DATABASE_URL=postgresql+psycopg2://nup:nup@localhost:5432/nup
REDIS_URL=redis://localhost:6379/0

S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=nup
S3_SECRET_KEY=nupnupnup
S3_BUCKET=nup-media
S3_REGION=us-east-1

OPENAI_API_KEY=
# Имя модели OpenAI. Если 'gpt-5.4' недоступна в твоём аккаунте,
# поменяй на gpt-4.1-mini / gpt-4o-mini / gpt-5-mini.
OPENAI_MODEL=gpt-5.4
# Сколько секунд между двумя постами в один и тот же канал (rate limiter).
PUBLISH_INTERVAL_SEC=10
ELEVENLABS_API_KEY=
PEXELS_API_KEY=
TELEGRAM_BOT_TOKEN=
# Канал, куда уходит финальный Reels после approval (F012).
TELEGRAM_CHANNEL_ID=-1003924811323
TELEGRAM_CHANNEL_USERNAME=@d_media_ai
# Telegram user_id оператора, кому бот шлёт превью на approve/decline/edit (F011).
OPERATOR_CHAT_ID=

# Anti-bot proxy pool (newline- or comma-separated). At least one required for ingestion.
PROXY_POOL=
PROXY_POOL_STRATEGY=round_robin   # round_robin | random | least_used

FFMPEG_BIN=ffmpeg
RENDER_TIMEOUT_SEC=180
